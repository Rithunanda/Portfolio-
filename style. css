body {
    font-family: Arial;
    margin: 0;
    background-color: #fff5f0;
}

/* Header */
header {
    background: #ffb4a2;
    color: white;
    text-align: center;
    padding: 20px;
}

/* Navigation */
nav ul {
    list-style: none;
    padding: 0;
}

nav ul li {
    display: inline;
    margin: 10px;
}

nav ul li a {
    text-decoration: none;
    color: white;
    background: #ff7f7f;
    padding: 8px 15px;
    border-radius: 5px;
}

nav ul li a:hover {
    background: #ff9770;
}

/* Sections */
section {
    background: white;
    margin: 20px;
    padding: 20px;
    border-radius: 10px;
}

/* Headings */
h2 {
    color: #ff7f7f;
}

/* Footer */
footer {
    text-align: center;
    background: #ffb4a2;
    color: white;
    padding: 10px;
}
